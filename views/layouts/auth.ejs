<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title>
    <%= typeof title !=='undefined' ? title : "Auth" %>
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>

<body>

  <%- body %>

    <!-- TOAST NOTIFICATIONS -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1100;">

      <% if (typeof success !=='undefined' && success.length> 0) { %>
        <% success.forEach(function(msg) { %>
          <div class="toast align-items-center text-white border-0 toast-success" role="alert" aria-live="assertive"
            aria-atomic="true">
            <div class="d-flex">
              <div class="toast-body d-flex align-items-center gap-2">
                <i class="fa-solid fa-circle-check fs-5"></i>
                <div>
                  <%= msg %>
                </div>
              </div>
              <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                aria-label="Close"></button>
            </div>
          </div>
          <% }) %>
            <% } %>

              <% if (typeof info !=='undefined' && info.length> 0) { %>
                <% info.forEach(function(msg) { %>
                  <div class="toast align-items-center text-white border-0 toast-info" role="alert"
                    aria-live="assertive" aria-atomic="true">
                    <div class="d-flex">
                      <div class="toast-body d-flex align-items-center gap-2">
                        <i class="fa-solid fa-circle-info fs-5"></i>
                        <div>
                          <%= msg %>
                        </div>
                      </div>
                      <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"
                        aria-label="Close"></button>
                    </div>
                  </div>
                  <% }) %>
                    <% } %>

                      <% if (typeof danger !=='undefined' && danger.length> 0) { %>
                        <% danger.forEach(function(msg) { %>
                          <div class="toast align-items-center text-white border-0 toast-danger" role="alert"
                            aria-live="assertive" aria-atomic="true">
                            <div class="d-flex">
                              <div class="toast-body d-flex align-items-center gap-2">
                                <i class="fa-solid fa-trash-can fs-5"></i>
                                <div>
                                  <%= msg %>
                                </div>
                              </div>
                              <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast" aria-label="Close"></button>
                            </div>
                          </div>
                          <% }) %>
                            <% } %>

                              <% if (typeof error !=='undefined' && error.length> 0) { %>
                                <% error.forEach(function(msg) { %>
                                  <div class="toast align-items-center text-white border-0 toast-danger" role="alert"
                                    aria-live="assertive" aria-atomic="true">
                                    <div class="d-flex">
                                      <div class="toast-body d-flex align-items-center gap-2">
                                        <i class="fa-solid fa-circle-xmark fs-5"></i>
                                        <div>
                                          <%= msg %>
                                        </div>
                                      </div>
                                      <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                        data-bs-dismiss="toast" aria-label="Close"></button>
                                    </div>
                                  </div>
                                  <% }) %>
                                    <% } %>

    </div>

    <style>
      .toast {
        border-radius: 12px;
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
        animation: toastSlideIn 0.3s ease-out;
      }

      .toast-success {
        background: rgba(25, 135, 84, 0.95) !important;
      }

      .toast-info {
        background: rgba(13, 110, 253, 0.95) !important;
      }

      .toast-danger {
        background: rgba(220, 53, 69, 0.95) !important;
      }

      @keyframes toastSlideIn {
        from {
          transform: translateY(100%) scale(0.9);
          opacity: 0;
        }

        to {
          transform: translateY(0) scale(1);
          opacity: 1;
        }
      }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Initialize Toasts -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const toastElList = [].slice.call(document.querySelectorAll('.toast'));
        const toastList = toastElList.map(function (toastEl) {
          return new bootstrap.Toast(toastEl, { delay: 4000 });
        });
        toastList.forEach(toast => toast.show());
      });
    </script>

</body>

</html>